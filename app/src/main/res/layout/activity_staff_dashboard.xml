<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cafe_bg_light"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <Button
        android:id="@+id/btnNewOrder"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginBottom="24dp"
        android:backgroundTint="@color/cafe_navy"
        android:text="New Order (Input Table)"
        android:textColor="@color/white"
        android:textSize="20sp" />

    <Button
        android:id="@+id/btnActiveOrders"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:backgroundTint="@color/cafe_pink"
        android:text="Active Orders &amp; Payments"
        android:textColor="@color/cafe_navy"
        android:textSize="20sp" />

    <Button
        android:id="@+id/btnTableStatus"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginTop="24dp"
        android:backgroundTint="#4CAF50"
        android:text="Update Table Status"
        android:textColor="@color/white"
        android:textSize="20sp" />
</LinearLayout>